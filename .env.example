# Supabase (created fresh for Vetly)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel AI Gateway (use plain provider/model strings, e.g. "anthropic/claude-haiku-4-5")
AI_GATEWAY_API_KEY=

# Stripe (test keys in dev, live keys in prod). No price ID — amounts are
# set at checkout time since donations are freeform.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (configured inside Supabase Auth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Cron auth (any random string; Vercel cron sends Authorization: Bearer $CRON_SECRET)
CRON_SECRET=
