{
  "name": "vetly",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @vetly/web dev",
    "dev:extension": "pnpm --filter @vetly/extension dev",
    "build:web": "pnpm --filter @vetly/web build",
    "build:extension": "pnpm --filter @vetly/extension build",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist .next node_modules && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  }
}
